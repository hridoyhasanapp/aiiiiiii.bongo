# GEMINI_API_KEY: Required for Gemini AI API calls. Can also be set in Admin Panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The Vercel deployment URL
APP_URL="https://your-app.vercel.app"

# JWT_SECRET: Secret key for signing Admin JWT tokens.
JWT_SECRET="android-ai-chat-super-secret-key-2026"

# NODE_ENV: Environment mode
NODE_ENV="production"
